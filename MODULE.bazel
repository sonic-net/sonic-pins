bazel_dep(name = "rules_go", version = "0.60.0")
bazel_dep(name = "rules_license", version = "1.0.0")
bazel_dep(name = "rules_pkg", version = "1.2.0")
bazel_dep(name = "rules_proto", version = "7.1.0")
bazel_dep(name = "fourward", version = "0.1.0")
bazel_dep(name = "z3", version = "4.15.2")

# Boost modules (individual Bzlmod modules replace the monolithic @boost).
bazel_dep(name = "boost.bimap", version = "1.90.0.bcr.1")
bazel_dep(name = "boost.graph", version = "1.90.0.bcr.1")
bazel_dep(name = "boost.multiprecision", version = "1.90.0.bcr.1")

# -- Overrides for deps not yet in BCR ----------------------------------------

# p4_infra is not yet in BCR; pinned to the Bzlmod migration PR.
# TODO: Switch to BCR once https://github.com/google/p4-infra/pull/61 lands.
git_override(
    module_name = "p4_infra",
    remote = "https://github.com/smolkaj/p4-infra.git",
    commit = "3f733593d4c2657ad8d8bc9d09cedab86a2eba94",
)

# 4ward P4 simulator — reference model for DVaaS output prediction and traces.
# TODO: Switch to BCR once 4ward is registered.
git_override(
    module_name = "fourward",
    remote = "https://github.com/smolkaj/4ward.git",
    commit = "e2da84c663bcae8b4e15276cf672bbe8e5e9da4a",
)

# p4c fork that exports //p4include as a Bazel package (needed by fourward_compile).
# Upstream PR: https://github.com/p4lang/p4c/pull/5533
# TODO: Drop once merged and released to BCR.
git_override(
    module_name = "p4c",
    remote = "https://github.com/smolkaj/p4c.git",
    commit = "c7e38ae7a338973098ab73d08f631c98c470b71c",
)

# -- JVM dependencies (for building the 4ward P4Runtime server) ---------------
# Module extensions are evaluated per-root-module, so 4ward's maven.install()
# artifacts must be redeclared here.

bazel_dep(name = "rules_jvm_external", version = "6.10")

maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")
maven.install(
    artifacts = [
        "com.google.protobuf:protobuf-java:4.29.3",
        "com.google.protobuf:protobuf-java-util:4.29.3",
        "com.google.protobuf:protobuf-kotlin:4.29.3",
        "io.grpc:grpc-kotlin-stub:1.4.3",
        "io.grpc:grpc-netty-shaded:1.68.1",
        "io.grpc:grpc-services:1.68.1",
        "org.jetbrains.kotlinx:kotlinx-coroutines-core:1.10.1",
        "org.jetbrains.kotlinx:kotlinx-coroutines-core-jvm:1.10.1",
        "javax.annotation:javax.annotation-api:1.3.2",
    ],
    known_contributing_modules = [
        "grpc-java",
        "protobuf",
    ],
    repositories = ["https://repo1.maven.org/maven2"],
)
use_repo(maven, "maven")

# -- Non-BCR dependencies (via module extension) ------------------------------

non_bcr_deps = use_extension("//:non_bcr_deps.bzl", "non_bcr_deps")
use_repo(
    non_bcr_deps,
    "com_github_otg_models",
    "sonic_swss_common",
)
